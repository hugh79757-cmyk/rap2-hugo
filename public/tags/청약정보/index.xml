 &lt;span
 class="absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none"&gt;
 &lt;a class="text-primary-300 dark:text-neutral-700 !no-underline" href="#%ec%b2%ad%ec%95%bd-%ec%9e%90%ea%b2%a9-%ec%a1%b0%ea%b1%b4" aria-label="앵커"&gt;#&lt;/a&gt;
 &lt;/span&gt;
 
&lt;/h2&gt;
